{
  "rules": {
    ".read": false,
    ".write": false,
    "presence": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['online','uid','ts'])"
      }
    },
    "global_telemetry": {
      "latest": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "live_arena": {
      ".read": "auth != null",
      ".write": false
    },
    "conversations_meta": {
      "$conversationId": {
        ".read": "auth != null",
        "lastUpdate": {
          ".write": "auth != null && newData.isNumber()"
        },
        "typing": {
          "$userId": {
            ".write": "auth != null && auth.uid === $userId",
            ".validate": "newData.isBoolean()"
          }
        }
      }
    }
  }
}
