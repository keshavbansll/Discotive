rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // =========================================================================
    // 1. PUBLIC AVATARS
    // =========================================================================
    match /avatars/{userId}/{imageId} {
      allow read: if true;
      allow create, update: if request.auth != null 
                           && request.auth.uid == userId
                           && request.resource.size <= 2 * 1024 * 1024 
                           && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // =========================================================================
    // 2. PRIVATE ASSET VAULT
    // =========================================================================
    match /vault/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null 
                           && request.auth.uid == userId
                           && request.resource.size <= 25 * 1024 * 1024 
                           && request.resource.contentType.matches('application/pdf|application/json|image/.*|text/.*|application/zip|application/x-zip-compressed|application/msword|application/vnd.openxmlformats-officedocument.*|application/vnd.ms-excel');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // =========================================================================
    // 3. COLIST COVERS (UPGRADED TOLERANCE)
    // =========================================================================
    match /colist_covers/{userId}/{imageId} {
      allow read: if true;
      allow create, update: if request.auth != null 
                           && request.auth.uid == userId
                           && request.resource.size <= 2 * 1024 * 1024 
                           && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}