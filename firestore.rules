// firestore.rules — v2.0 — Vault + Connectors allowlisted
// Deploy: firebase deploy --only firestore:rules  (run in project root)
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================================
    // SECURITY UTILS
    // =========================================================================
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isValidMapDocument(doc) {
      return doc.keys().hasAll(['nodes', 'edges', 'updatedAt'])
        && doc.nodes is list
        && doc.edges is list
        && doc.nodes.size() <= 200
        && doc.edges.size() <= 500;
    }

    // =========================================================================
    // 0. ADMIN REGISTRY
    // =========================================================================
    match /admins/{adminId} {
      allow read: if isOwner(adminId) || isAdmin();
      allow write: if false;
    }

     // =========================================================================
    // SYSTEM CONFIG (Admin write only, auth read)
    // =========================================================================
    match /system/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // =========================================================================
    // 1. EMAIL VERIFICATIONS
    // =========================================================================
    match /email_verifications/{email} {
      allow read: if isAuthenticated() && request.auth.token.email == email;
      allow write: if false;
    }

    // =========================================================================
    // 2. DISCOTIVE LEARN ENGINE
    // =========================================================================
    match /discotive_videos/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /discotive_certificates/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /learn_suggestions/{suggestionId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated()
        && request.resource.data.submittedBy == request.auth.uid
        && request.resource.data.status == "PENDING"
        && request.resource.data.title is string
        && request.resource.data.url is string;
      allow update, delete: if isAdmin();
    }
    match /opportunities/{opportunityId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /app_catalog/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /app_verifications/{document=**} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // =========================================================================
    // 3. SUPPORT & TELEMETRY
    // =========================================================================
    match /support_tickets/{ticketId} {
      allow read: if isAdmin()
        || (isAuthenticated() && resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.subject is string
        && request.resource.data.subject.size() <= 200
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 2000;
      allow update: if isAdmin()
        || (isAuthenticated()
          && resource.data.uid == request.auth.uid
          && request.resource.data.diff(resource.data)
              .affectedKeys().hasOnly(['status']));
      allow delete: if isAdmin();
    }
    match /reports/{reportId} {
      allow read: if isAdmin()
        || (isAuthenticated() && resource.data.reporterUid == request.auth.uid);
      allow create: if isAuthenticated()
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.reason is string
        && request.resource.data.reason.size() <= 200;
      allow update, delete: if isAdmin();
    }
    match /feedback/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow write: if isOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.rating is number
        && request.resource.data.rating >= 0
        && request.resource.data.rating <= 5;
    }

    // =========================================================================
    // 4. CORE USER AUTH LEDGER
    // =========================================================================
    match /users/{userId} {
      allow read: if true;

      allow create: if isOwner(userId)
        && (!("tier" in request.resource.data) || request.resource.data.tier == "ESSENTIAL")
        && (!("discotiveScore" in request.resource.data) || request.resource.data.discotiveScore.current == 0)
        && request.resource.data.onboarding_status in ["pending", "completed"];

      allow delete: if isOwner(userId);

      allow update: if
        (isOwner(userId)
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly([
                // Onboarding completion
                'onboarding_status', 'onboardingComplete', 'isGhostUser',
                'createdAt', 'onboardingScoreAwarded',

                // Identity & profile fields
                'identity', 'links', 'footprint', 'settings', 'professional',
                'vision', 'skills', 'resources', 'wildcard', 'discotiveId',
                'profileViews', 'pendingAppVerifications', 'profileCompleteness',
                'deferredOnboarding', 'baseline',

                // ─── VAULT ───────────────────────────────────────────────────
                // Vault array: uploaded files, synced connector assets.
                // Owner-writable. Admin can also write (for verification updates).
                'vault', 'vault_count',

                // ─── CONNECTORS ──────────────────────────────────────────────
                // Third-party connector state (GitHub username, YouTube channel,
                // Stripe key refs, etc.). Owner manages connection metadata.
                // Token storage is handled via Cloud Functions only.
                'connectors', 'connectedApps',

                // Gamification & Consistency Engine
                'discotiveScore', 'score_history', 'consistency_log',
                'login_history', 'daily_scores', 'monthly_scores',
                'dailyAllianceSent', 'journal_ledger',

                // UI States
                'notifications', 'hasUnreadNotifications',

                // Allies (written by Cloud Functions for alliance logic)
                'allies'
              ]))
        || isAdmin();
    }

    // =========================================================================
    // 5. PUBLIC PROFILES
    // =========================================================================
    match /profiles/{userId} {
      allow read: if true;

      allow create: if isOwner(userId)
        && get(/databases/$(database)/documents/users/$(userId))
            .data.onboarding_status == "completed";

      allow update: if isOwner(userId)
        && get(/databases/$(database)/documents/users/$(userId))
            .data.onboarding_status == "completed"
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly([
              'identity', 'vision', 'skills', 'baseline', 'footprint',
              'links', 'bio', 'domain', 'niche', 'country', 'userState',
              'institution', 'course', 'guardianProfession', 'updatedAt',
              'profileCompleteness', 'tier', 'avatarUrl',
              'followedSeeds', 'publicBadges', 'featuredAssets'
            ]);

      allow delete: if isOwner(userId) || isAdmin();
    }

    // =========================================================================
    // 6. USER METRICS
    // =========================================================================
    match /user_metrics/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      allow create: if isOwner(userId)
        && (!("discotiveScore" in request.resource.data)
          || request.resource.data.discotiveScore.current == 0);

      allow update: if isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly([
              'discotiveScore', 'score_history', 'consistency_log',
              'login_history', 'daily_scores', 'monthly_scores',
              'dailyAllianceSent', 'precomputed', 'tier'
            ])
        || isAdmin();

      allow delete: if isAdmin();
    }

    // =========================================================================
    // 7. EXECUTION MAP
    // =========================================================================
    match /users/{userId}/execution_map/current {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isValidMapDocument(request.resource.data);
    }
    match /users/{userId}/execution_map/{docId} {
      allow read, write: if docId == "current" && isOwner(userId);
    }

    // =========================================================================
    // 8. VERIFICATION REQUESTS
    // =========================================================================
    match /users/{userId}/verification_requests/{reqId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId)
        && request.resource.data.status == "PENDING"
        && !("ai_grade" in request.resource.data)
        && !("ghostUnlockTimeMs" in request.resource.data)
        && request.resource.data.payload is string
        && request.resource.data.payload.size() >= 5
        && request.resource.data.payload.size() <= 5000;
      allow update, delete: if isAdmin();
    }

    // =========================================================================
    // 9. SUBSCRIPTION — Read owner, write CF only
    // =========================================================================
    match /users/{userId}/subscription/{document=**} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    // =========================================================================
    // 10. JOURNAL — PRO/ENTERPRISE only
    // =========================================================================
    match /users/{userId}/journal/{entryId} {
      allow read, write: if isOwner(userId)
        && get(/databases/$(database)/documents/users/$(userId))
            .data.tier in ["PRO", "ENTERPRISE"];
    }
    match /users/{userId}/journal_entries/{document=**} {
      allow read, write: if isOwner(userId)
        && get(/databases/$(database)/documents/users/$(userId))
            .data.tier in ["PRO", "ENTERPRISE"];
    }

    // =========================================================================
    // 11. SCORE LOG
    // =========================================================================
    match /users/{userId}/score_log/{document=**} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && request.resource.data.change is number
        && request.resource.data.reason is string
        && request.resource.data.score is number;
      allow update, delete: if isAdmin();
    }

    // =========================================================================
    // 12. VAULT SUBCOLLECTION (legacy path — primary vault lives on users doc)
    // =========================================================================
    match /users/{userId}/vault/{assetId} {
      allow read: if (resource.data.isPublic == true)
        || isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    // =========================================================================
    // 13. VAULT REPORTS (admin-generated from VaultVerification)
    // =========================================================================
    match /vault_reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // =========================================================================
    // NETWORK MODULE
    // =========================================================================
    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.textContent is string
        && request.resource.data.textContent.size() >= 1
        && request.resource.data.textContent.size() <= 2000
        && request.resource.data.likedBy is list
        && request.resource.data.likedBy.size() == 0;
      allow update: if isAuthenticated()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['likedBy', 'likesCount', 'replyCount', 'bounty']);
      allow delete: if isAdmin()
        || (isAuthenticated() && resource.data.authorId == request.auth.uid);
    }
    match /connections/{connectionId} {
      allow read: if isAuthenticated()
        && (resource.data.requesterId == request.auth.uid
          || resource.data.receiverId == request.auth.uid);
      allow create: if isAuthenticated()
        && request.resource.data.requesterId == request.auth.uid
        && request.resource.data.receiverId != request.auth.uid
        && request.resource.data.status == "PENDING"
        && request.resource.data.requesterName is string
        && request.resource.data.receiverName is string;
      allow update: if isAuthenticated()
        && (
          (resource.data.receiverId == request.auth.uid
            && resource.data.status == "PENDING"
            && request.resource.data.status == "ALLIANCE"
            && request.resource.data.diff(resource.data)
                .affectedKeys().hasOnly(['status', 'acceptedAt']))
          || (resource.data.receiverId == request.auth.uid
            && resource.data.status == "PENDING"
            && request.resource.data.status == "DECLINED"
            && request.resource.data.diff(resource.data)
                .affectedKeys().hasOnly(['status', 'declinedAt']))
        );
      allow delete: if isAuthenticated()
        && (resource.data.requesterId == request.auth.uid
          || resource.data.receiverId == request.auth.uid);
    }
    match /competitors/{competitorId} {
      allow read: if isAuthenticated() && resource.data.trackerId == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.trackerId == request.auth.uid
        && request.resource.data.targetId != request.auth.uid
        && request.resource.data.targetId is string;
      allow delete: if isAuthenticated() && resource.data.trackerId == request.auth.uid;
      allow update: if false;
    }
    match /posts/{postId}/comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.textContent is string
        && request.resource.data.textContent.size() >= 1
        && request.resource.data.textContent.size() <= 500
        && request.resource.data.likedBy is list
        && request.resource.data.likedBy.size() == 0;
      allow update: if isAuthenticated()
        && request.resource.data.diff(resource.data)
            .affectedKeys().hasOnly(['likedBy', 'likesCount']);
      allow delete: if isAuthenticated()
        && (resource.data.authorId == request.auth.uid || isAdmin());
    }
    match /conversations/{conversationId} {
      allow read: if isAuthenticated()
        && resource.data.participantIds.hasAny([request.auth.uid]);
      allow create: if isAuthenticated()
        && request.resource.data.participantIds.hasAny([request.auth.uid])
        && request.resource.data.participantIds.size() == 2;
      allow update: if isAuthenticated()
        && resource.data.participantIds.hasAny([request.auth.uid])
        && request.resource.data.diff(resource.data,)
            .affectedKeys().hasOnly([
              'lastMessage', 'lastMessageAt', 'lastSenderId',
              'unreadCounts', 'updatedAt'
            ]);
      allow delete: if isAdmin()
        || (isAuthenticated() && resource.data.participantIds.hasAny([request.auth.uid]));
    }
    match /conversations/{conversationId}/messages/{messageId} {
      allow read: if isAuthenticated()
        && get(/databases/$(database)/documents/conversations/$(conversationId))
            .data.participantIds.hasAny([request.auth.uid]);
      allow create: if isAuthenticated()
        && request.resource.data.senderId == request.auth.uid
        && get(/databases/$(database)/documents/conversations/$(conversationId))
            .data.participantIds.hasAny([request.auth.uid])
        && request.resource.data.textContent is string
        && request.resource.data.textContent.size() >= 1
        && request.resource.data.textContent.size() <= 2000;
      allow delete: if isAdmin()
        || (isAuthenticated() && resource.data.senderId == request.auth.uid);
      allow update: if isAuthenticated()
        && resource.data.senderId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['textContent', 'isEdited', 'editedAt', 'updatedAt']);
    }
    match /bounty_escrow/{postId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
  }
}
