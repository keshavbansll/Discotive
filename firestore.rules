rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================================
    // SECURITY UTILS
    // =========================================================================
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ── Validates the TOP-LEVEL execution map document (nodes[] + edges[]) ──
    // Does NOT try to validate individual node fields — that's the Cloud Function's job.
    function isValidMapDocument(doc) {
      return doc.keys().hasAll(['nodes', 'edges', 'updatedAt'])
        && doc.nodes is list
        && doc.edges is list
        && doc.nodes.size() <= 200
        && doc.edges.size() <= 500;
    }

    // ── Validates a score mutation from the client (scoreEngine.js) ──
    // Only allows changes to fields that score engine legitimately updates.
    function isLegitScoreWrite(incoming, existing) {
      let allowedScoreKeys = [
        'discotiveScore.current', 'discotiveScore.lastLoginDate',
        'discotiveScore.streak', 'discotiveScore.lastAmount',
        'discotiveScore.lastReason', 'discotiveScore.lastUpdatedAt',
        'discotiveScore.last24h', 'daily_scores', 'monthly_scores',
        'consistency_log', 'login_history'
      ];
      let changedKeys = incoming.data.diff(existing.data).affectedKeys();
      return changedKeys.hasOnly(allowedScoreKeys);
    }

    // =========================================================================
    // 1. ADMIN REGISTRY — Read-only for owner/admin, never writable by client
    // =========================================================================
    match /admins/{adminId} {
      allow read: if isOwner(adminId) || isAdmin();
      allow write: if false;
    }

    // =========================================================================
    // 2. EMAIL VERIFICATIONS — Owned by email address, written by CF only
    // =========================================================================
    match /email_verifications/{email} {
      allow read: if isAuthenticated()
        && request.auth.token.email == email;
      allow write: if false;
    }

    // =========================================================================
    // 3. DISCOTIVE LEARN ENGINE — Read-authenticated, write admin-only
    // =========================================================================
    match /discotive_videos/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /discotive_certificates/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // =========================================================================
    // 4. TELEMETRY — Sanitized writes via Cloud Functions preferred;
    //    direct client writes allowed but strictly validated
    // =========================================================================
    match /support_tickets/{ticketId} {
      allow read: if isAdmin()
        || (isAuthenticated() && resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.subject is string
        && request.resource.data.subject.size() <= 200
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 2000;
      allow update: if isAdmin()
        || (isAuthenticated()
          && resource.data.uid == request.auth.uid
          && request.resource.data.diff(resource.data)
              .affectedKeys().hasOnly(['status']));
      allow delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow read: if isAdmin()
        || (isAuthenticated() && resource.data.reporterUid == request.auth.uid);
      allow create: if isAuthenticated()
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.reason is string
        && request.resource.data.reason.size() <= 200;
      allow update, delete: if isAdmin();
    }

    match /feedback/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow write: if isOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.rating is number
        && request.resource.data.rating >= 0
        && request.resource.data.rating <= 5;
    }

    // =========================================================================
    // 5. CORE USER LEDGER — Strict field-level security
    // =========================================================================
    match /users/{userId} {
      // Anyone authenticated can read public profile data
      allow read: if isAuthenticated();

      // User creation: owner only, must set their own UID
      allow create: if isOwner(userId);

      // Soft-delete: owner only
      allow delete: if isOwner(userId);

      // Update: Four distinct allowed paths
      allow update: if
        // Path A: Owner updates personal data (BLOCKS score escalation & tier changes)
        (isOwner(userId)
          && !request.resource.data.diff(resource.data)
              .affectedKeys().hasAny([
                'tier', 'isGhostUser', 'discotiveScore', 'score',
                'profileViews', 'onboardingScoreAwarded', 'precomputed'
              ]))

        // Path B: Score engine writes (client-side scoreEngine.js transactions)
        || (isOwner(userId) && isLegitScoreWrite(request.resource, resource))

        // Path C: Alliance cross-writes (another user sending/accepting requests)
        || (isAuthenticated()
          && request.resource.data.diff(resource.data)
              .affectedKeys().hasOnly([
                'inboundRequests', 'outboundRequests', 'allies',
                'dailyAllianceSent'
              ]))

        // Path D: Profile view counter (any authenticated user, increment-only)
        || (isAuthenticated()
          && request.resource.data.diff(resource.data)
              .affectedKeys().hasOnly(['profileViews'])
          && request.resource.data.profileViews
              == resource.data.profileViews + 1)

        // Path E: Onboarding completion (owner only, one-time flag)
        || (isOwner(userId)
          && request.resource.data.diff(resource.data)
              .affectedKeys().hasOnly([
                'onboardingComplete', 'isGhostUser',
                'identity', 'vision', 'skills', 'baseline',
                'footprint', 'links', 'settings'
              ]))

        // Path F: Compare/leaderboard metadata (owner only)
        || (isOwner(userId)
          && request.resource.data.diff(resource.data)
              .affectedKeys().hasOnly(['dailyComparisons']))

        // Path G: Notification writes (owner or ally cross-write)
        || (isAuthenticated()
          && request.resource.data.diff(resource.data)
              .affectedKeys().hasOnly(['notifications']))

        // Path H: Admin override (superuser)
        || isAdmin();
    }

    // =========================================================================
    // 6. EXECUTION MAP — Single document at /current, array-based
    // =========================================================================
    // The execution map is ONE document: users/{uid}/execution_map/current
    // It contains { nodes: [], edges: [], updatedAt: timestamp, mapMeta: {} }
    match /users/{userId}/execution_map/current {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isValidMapDocument(request.resource.data);
    }
    // Block any other documents in this subcollection
    match /users/{userId}/execution_map/{docId} {
      allow read, write: if docId == "current" && isOwner(userId);
    }

    // =========================================================================
    // 7. VERIFICATION REQUESTS — Owner create, admin update
    // =========================================================================
    match /users/{userId}/verification_requests/{reqId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId)
        && request.resource.data.status == "PENDING"
        && !("ai_grade" in request.resource.data)
        && !("ghostUnlockTimeMs" in request.resource.data)
        && request.resource.data.payload is string
        && request.resource.data.payload.size() >= 5
        && request.resource.data.payload.size() <= 5000;
      allow update, delete: if isAdmin();
    }

    // =========================================================================
    // 8. SUBSCRIPTION — Read owner, write CF only (no client writes)
    // =========================================================================
    match /users/{userId}/subscription/{document=**} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    // =========================================================================
    // 9. JOURNAL — PRO/ENTERPRISE only, owner-scoped
    // =========================================================================
    // JournalModal writes to /users/{uid}/journal/{dateStr}
    match /users/{userId}/journal/{entryId} {
      allow read, write: if isOwner(userId)
        && get(/databases/$(database)/documents/users/$(userId))
            .data.tier in ["PRO", "ENTERPRISE"];
    }
    // Legacy path (journal_entries) — keep for backward compat
    match /users/{userId}/journal_entries/{document=**} {
      allow read, write: if isOwner(userId)
        && get(/databases/$(database)/documents/users/$(userId))
            .data.tier in ["PRO", "ENTERPRISE"];
    }

    // =========================================================================
    // 10. SCORE LOG — Owner read/create, admin modify
    // =========================================================================
    match /users/{userId}/score_log/{document=**} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && request.resource.data.change is number
        && request.resource.data.reason is string
        && request.resource.data.score is number;
      allow update, delete: if isAdmin();
    }

    // =========================================================================
    // 11. ASSET VAULT (array field on user doc, not subcollection)
    // Vault assets are stored in users/{userId}.vault[] array.
    // The subcollection path below is legacy/unused — kept for migration safety.
    // =========================================================================
    match /users/{userId}/vault/{assetId} {
      allow read: if (resource.data.isPublic == true)
        || isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    // =========================================================================
    // NETWORK MODULE FIRESTORE RULES
    // =========================================================================

    // =========================================================================
    // N1. POSTS — Authenticated write, public read within auth scope
    // =========================================================================
    match /posts/{postId} {
      // Any authenticated user can read posts (feed is visible to all operators)
      allow read: if isAuthenticated();

      // Create: only the owner, must carry their own uid as authorId
      allow create: if isAuthenticated()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.textContent is string
        && request.resource.data.textContent.size() >= 1
        && request.resource.data.textContent.size() <= 2000
        && request.resource.data.likedBy is list
        && request.resource.data.likedBy.size() == 0;  // No pre-seeding likes

      // Update: ONLY allow changes to likedBy and likesCount (like/unlike).
      // Author cannot edit post content after publishing (integrity).
      allow update: if isAuthenticated()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['likedBy', 'likesCount']);

      // Delete: only the author
      allow delete: if isAuthenticated()
        && resource.data.authorId == request.auth.uid;
    }

    // =========================================================================
    // N2. CONNECTIONS — Strict requester-ownership, both parties can read
    // =========================================================================
    match /connections/{connectionId} {
      // Both parties involved can read the connection document
      allow read: if isAuthenticated()
        && (resource.data.requesterId == request.auth.uid
          || resource.data.receiverId == request.auth.uid);

      // Create: only the requester, status MUST be PENDING (no self-alliances)
      allow create: if isAuthenticated()
        && request.resource.data.requesterId == request.auth.uid
        && request.resource.data.receiverId != request.auth.uid
        && request.resource.data.status == "PENDING"
        && request.resource.data.requesterName is string
        && request.resource.data.receiverName is string;

      // Update: ONLY the receiver can accept (PENDING → ALLIANCE) or
      //         either party can set to DECLINED (receiver) or delete (requester cancel)
      allow update: if isAuthenticated()
        && (
          // Receiver accepts: PENDING → ALLIANCE
          (resource.data.receiverId == request.auth.uid
            && resource.data.status == "PENDING"
            && request.resource.data.status == "ALLIANCE"
            && request.resource.data.diff(resource.data)
                .affectedKeys().hasOnly(['status', 'acceptedAt']))
          // Receiver declines: PENDING → DECLINED
          || (resource.data.receiverId == request.auth.uid
            && resource.data.status == "PENDING"
            && request.resource.data.status == "DECLINED"
            && request.resource.data.diff(resource.data)
                .affectedKeys().hasOnly(['status', 'declinedAt']))
        );

      // Delete: requester can cancel PENDING requests, either party can remove ALLIANCE
      allow delete: if isAuthenticated()
        && (resource.data.requesterId == request.auth.uid
          || resource.data.receiverId == request.auth.uid);
    }

    // =========================================================================
    // N3. COMPETITORS — Tracker owns the document (one-way tracking)
    // =========================================================================
    match /competitors/{competitorId} {
      // Only the tracker can read their competitor list
      allow read: if isAuthenticated()
        && resource.data.trackerId == request.auth.uid;

      // Create: tracker must be the authenticated user, no self-tracking
      allow create: if isAuthenticated()
        && request.resource.data.trackerId == request.auth.uid
        && request.resource.data.targetId != request.auth.uid
        && request.resource.data.targetId is string;

      // Delete: only the tracker (untrack)
      allow delete: if isAuthenticated()
        && resource.data.trackerId == request.auth.uid;

      // No updates — immutable. Delete and recreate if needed.
      allow update: if false;
    }
  }
}

